# Advanced Docker deployment overrides
#
# Normal local startup does not require this file. Run:
#   docker compose -f deploy/docker-compose.yml up -d
# Then configure Medplum, OIE, GDT Bridge, dcm4chee, and AP connections in the
# Healthcare Lab Settings UI. Copy this file to .env only when a deployment
# override or one-time legacy bootstrap value is required.

# Immutable image selection
LAB_APP_IMAGE=ghcr.io/tzu-huang/healthcare-lab:1.0.1
# OIE_IMAGE=nextgenhealthcare/connect:4.5.2@sha256:4afa295cfe7c5ffd596efee69594157fea87202e33d66bb4a98a52db4598f836
# MEDPLUM_IMAGE=medplum/medplum-server@sha256:4d2c8e926fe536176a88a7e24555f97f92226e39f171bd0b5f0c7f667d0bf9f0
# MEDPLUM_APP_IMAGE=medplum/medplum-app@sha256:79f162f7124a8932c2a76fc2c7c72df4b080d5fef43496c64bc34ad68e65ca56
# MEDPLUM_POSTGRES_IMAGE=postgres:16-alpine@sha256:e013e867e712fec275706a6c51c966f0bb0c93cfa8f51000f85a15f9865a28cb
# MEDPLUM_REDIS_IMAGE=redis:7-alpine@sha256:6ab0b6e7381779332f97b8ca76193e45b0756f38d4c0dcda72dbb3c32061ab99
# DCM4CHEE_IMAGE=dcm4che/dcm4chee-arc-psql:5.35.0@sha256:20a195c0c53336e1d0c7bdc30536d46611a939f0a2e25dec3318c8d99d7fba29
# DCM4CHEE_DB_IMAGE=dcm4che/postgres-dcm4chee:16.13-35@sha256:1fced918fa507a133ec98db6ad2af92be2db0399c4061d5d59a4405ac445cd70
# DCM4CHEE_LDAP_IMAGE=dcm4che/slapd-dcm4chee:2.6.13-35.0@sha256:ca45eaf70d92c4008612ab345a566e06c13b553b079ccf6c652ceda4c9a98b98

# Host-published ports. Container-to-container endpoints stay fixed.
LAB_APP_PORT=5000
OIE_HTTP_PORT=8080
OIE_HTTPS_PORT=8443
OIE_AP_RESULT_INGRESS_HOST_PORT=6661
OIE_ORDER_INGRESS_HOST_PORT=6600
MEDPLUM_PORT=8103
MEDPLUM_APP_PORT=3000
DCM4CHEE_HTTP_PORT=8082
DCM4CHEE_DICOM_PORT=11112
DCM4CHEE_HL7_HOST_PORT=2575

# Optional host-visible GDT exchange root. The wrapper safely creates the exact
# path before start. Leave blank for instance/gdt-bridge under this repository.
GDT_BRIDGE_HOST_PATH=

# Local service database identities and security hardening. Checked-in Compose
# defaults are for a trusted local lab only; replace secrets for other contexts.
OIE_DATABASE=derby
MEDPLUM_POSTGRES_DB=medplum
MEDPLUM_POSTGRES_USER=medplum
MEDPLUM_POSTGRES_PASSWORD=medplum
MEDPLUM_ALLOWED_ORIGINS=http://127.0.0.1:3000,http://localhost:3000
MEDPLUM_APP_BASE_URL=http://127.0.0.1:3000/
MEDPLUM_BASE_URL=http://127.0.0.1:8103/
MEDPLUM_PUBLIC_BASE_URL=http://127.0.0.1:8103/
MEDPLUM_RECAPTCHA_SITE_KEY=6LfHdsYdAAAAAC0uLnnRrDrhcXnziiUwKd8VtLNq
MEDPLUM_RECAPTCHA_SECRET_KEY=
DCM4CHEE_DB_NAME=pacsdb
DCM4CHEE_DB_USER=pacs
DCM4CHEE_DB_PASSWORD=pacs
DCM4CHEE_LDAP_ROOTPASS=secret
DCM4CHEE_LDAP_URL=ldap://ldap:389
DCM4CHEE_LDAP_BASE_DN=dc=dcm4che,dc=org
DCM4CHEE_STORAGE_DIR=/storage/fs1

# Startup policy is a process-level deployment override, not a Settings value.
OIE_BOOTSTRAP_MODE=create-missing
OIE_BOOTSTRAP_TIMEOUT_SECONDS=120
OIE_BOOTSTRAP_RETRY_INTERVAL_SECONDS=2

# One-time compatibility bootstrap
#
# Existing installations may retain legacy application values in their local
# .env during the upgrade. Compose passes only a fixed allowlist to lab-app.
# A value seeds a missing typed profile once; an existing persisted Settings
# profile always wins on later starts. New installs should use Settings instead.
#
# MEDPLUM_CLIENT_ID=
# MEDPLUM_CLIENT_SECRET=
# OPENEMR_DB_HOST=
# OPENEMR_DB_PORT=3306
# OPENEMR_DB_USER=openemr
# OPENEMR_DB_PASSWORD=
# OPENEMR_DB_NAME=openemr
# OPENEMR_GDT_PROCEDURE_CODES=1001
#
# Deprecated OIE listener aliases remain accepted for one migration window:
# OIE_MLLP_RESULT_HOST=0.0.0.0
# OIE_MLLP_RESULT_PORT=6665
