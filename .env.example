# Published lab-app image used by Docker Compose. Override this deliberately to
# test another immutable version or a local build such as healthcare-lab:dev.
LAB_APP_IMAGE=ghcr.io/tzu-huang/healthcare-lab:1.0.1

# Medplum OAuth client credentials for lab-app server-to-server FHIR access.
# Create these in Medplum for the target environment, keep the real secret out
# of Git, and restart lab-app after changing either value.
MEDPLUM_CLIENT_ID=
MEDPLUM_CLIENT_SECRET=

# Optional Medplum auth tuning. Leave MEDPLUM_TOKEN_URL blank to derive
# /oauth2/token from the configured FHIR base URL.
MEDPLUM_SCOPE=
MEDPLUM_TOKEN_URL=
MEDPLUM_AUTH_GRACE_SECONDS=300
MEDPLUM_APP_PORT=3000
MEDPLUM_APP_BASE_URL=http://127.0.0.1:3000/
MEDPLUM_ALLOWED_ORIGINS=http://127.0.0.1:3000,http://localhost:3000
MEDPLUM_PUBLIC_BASE_URL=http://127.0.0.1:8103/
MEDPLUM_RECAPTCHA_SITE_KEY=6LfHdsYdAAAAAC0uLnnRrDrhcXnziiUwKd8VtLNq
MEDPLUM_RECAPTCHA_SECRET_KEY=

# Optional external OpenEMR procedure-order source. The default Compose runtime
# does not provision OpenEMR or MariaDB; leave these blank for local-only GDT.
ECG_FILE_BASE_URL=https://ecg.example.com
OPENEMR_DB_HOST=
OPENEMR_DB_PORT=3306
OPENEMR_DB_USER=openemr
OPENEMR_DB_PASSWORD=your-openemr-db-password
OPENEMR_DB_NAME=openemr
OPENEMR_GDT_PROCEDURE_CODES=1001
# HLAB listener inside lab-app; OIE sends results to lab-app:6665 over Docker.
HLAB_RESULT_LISTENER_HOST=0.0.0.0
HLAB_RESULT_LISTENER_PORT=6665

# Host publications for AP/result traffic into OIE and HLAB/order traffic into OIE.
# These do not change the Docker-network Channel endpoints (oie:6661/oie:6600).
OIE_AP_RESULT_INGRESS_HOST_PORT=6661
OIE_ORDER_INGRESS_HOST_PORT=6600

# One-release migration aliases: when the corresponding HLAB_RESULT_LISTENER_*
# value is unset, lab-app accepts OIE_MLLP_RESULT_HOST/PORT. These deprecated
# aliases never control an OIE host-published port.
# OIE_MLLP_RESULT_HOST=0.0.0.0
# OIE_MLLP_RESULT_PORT=6665

# dcm4chee-arc Docker connection profile. Browser-facing URLs use the published
# host port; lab-app-to-dcm4chee traffic uses the Docker service name and
# container ports. See README.md for direct host-development overrides.
DCM4CHEE_PROFILE_NAME=local-dcm4chee
DCM4CHEE_DISPLAY_NAME=dcm4chee Local Archive
DCM4CHEE_ENVIRONMENT_NAME=local-docker
DCM4CHEE_WEB_UI_URL=http://127.0.0.1:8082/dcm4chee-arc/ui2
DCM4CHEE_DIMSE_HOST=dcm4chee
DCM4CHEE_DIMSE_PORT=11112
DCM4CHEE_CALLED_AE_TITLE=DCM4CHEE
DCM4CHEE_CALLING_AE_TITLE=HEALTHCARE_LAB
DCM4CHEE_MWL_AE_TITLE=WORKLIST
DCM4CHEE_DEFAULT_SCHEDULED_STATION_AE_TITLE=ECG_AP
DCM4CHEE_HL7_HOST=dcm4chee
DCM4CHEE_HL7_PORT=2575
DCM4CHEE_HL7_SENDING_APPLICATION=HEALTHCARE_LAB
DCM4CHEE_HL7_SENDING_FACILITY=LAB_APP
DCM4CHEE_HL7_RECEIVING_APPLICATION=DCM4CHEE
DCM4CHEE_HL7_RECEIVING_FACILITY=DCM4CHEE
DCM4CHEE_PATIENT_ASSIGNING_AUTHORITY=local-dcm4chee
DCM4CHEE_DICOMWEB_BASE_URL=http://dcm4chee:8080/dcm4chee-arc/aets/WORKLIST/rs
# QIDO/WADO/STOW target the archive AE used for AP C-STORE results.
DCM4CHEE_QIDO_RS_URL=http://dcm4chee:8080/dcm4chee-arc/aets/DCM4CHEE/rs
DCM4CHEE_WADO_RS_URL=http://dcm4chee:8080/dcm4chee-arc/aets/DCM4CHEE/rs
DCM4CHEE_STOW_RS_URL=http://dcm4chee:8080/dcm4chee-arc/aets/DCM4CHEE/rs
DCM4CHEE_VIEWER_STUDY_URL_TEMPLATE=
DCM4CHEE_UID_ROOT=1.2.826.0.1.3680043.10.543
DCM4CHEE_AUTH_MODE=none
DCM4CHEE_TLS_ENABLED=false
DCM4CHEE_TLS_VERIFY=true
DCM4CHEE_USERNAME=
DCM4CHEE_TOKEN_URL=
DCM4CHEE_CERTIFICATE_PATH=
DCM4CHEE_PRIVATE_KEY_PATH=

# Optional host folder for the Docker GDT shared folder. Create and manage the
# folder structure yourself: Healthcare Lab writes orders to inbox and reads
# returned data from outbox. The app only stores the configured path.
# Compose mounts this computer folder to /data/gdt-bridge inside lab-app.
# Leave blank to use ./instance/gdt-bridge through the compose default.
# Example on Windows:
# GDT_BRIDGE_HOST_PATH=C:\Personal_repo\Projects\healthcare-lab\instance\gdt-bridge
GDT_BRIDGE_HOST_PATH=
GDT_BRIDGE_IMPORT_SUCCESS_MODE=archive
GDT_BRIDGE_FILENAME_PROFILE=permissive
GDT_BRIDGE_RECEIVER_ID=
GDT_BRIDGE_SENDER_ID=
GDT_BRIDGE_WATCH_POLL_SECONDS=2
GDT_BRIDGE_STABLE_SECONDS=1
